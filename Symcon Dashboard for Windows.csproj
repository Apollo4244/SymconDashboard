<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <RootNamespace>SymconDashboard</RootNamespace>
    <Nullable>enable</Nullable>
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>enable</ImplicitUsings>
    <ApplicationIcon>app.ico</ApplicationIcon>
    <PlatformTarget>AnyCPU</PlatformTarget>
    <Version>1.0.5</Version>
    <AssemblyName>SymconDashboard</AssemblyName>
    <!-- Bei PublishSingleFile: keine .pdb und keine NuGet-Doku-XMLs neben der EXE -->
    <DebugType Condition="'$(PublishSingleFile)' == 'true'">none</DebugType>
    <AllowedReferenceRelatedFileExtensions Condition="'$(PublishSingleFile)' == 'true'">none</AllowedReferenceRelatedFileExtensions>
  </PropertyGroup>

  <ItemGroup>
    <None Include=".github\workflows\release.yml" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Web.WebView2" Version="1.0.3296.44" />
  </ItemGroup>

</Project>